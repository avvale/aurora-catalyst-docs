{
  "name": "aurora-catalyst-docs",
  "version": "0.1.0",
  "type": "module",
  "description": "Aurora Catalyst documentation site (CLI + framework).",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
