{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx \"$CLAUDE_PROJECT_DIR/.claude/scripts/generate-skills-index.ts\"",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": ".claude/scripts/status-line.sh"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(pnpm start)",
      "Bash(pnpm build)"
    ]
  },
  "additionalWorkingDirectories": [
    "~/Projects/aurora/aurora-catalyst-cli",
    "~/Projects/aurora/aurora-catalyst"
  ]
}